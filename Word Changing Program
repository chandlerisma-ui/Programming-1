int DetermineRULE(char upperWord[])
{
    int len = strlen(upperWord);

    if (upperWord[len - 1] == 'S' && upperWord[len - 2] == 'U') 
    {
        return 1;
    }
    else if (upperWord[len - 1] == 'S' && upperWord[len - 2] == 'S') 
    {
        return 2;
    }

    else if (upperWord[len - 1] == 'H' && upperWord[len - 2] == 'S')
    {
        return 2;
    }

    else if (upperWord[len - 1] == 'H' && upperWord[len - 2] == 'C')
    {
        return 2;
    }

    else if (upperWord[len - 1] == 'X')
    {
        return 2;
    }

    else if (upperWord[len - 1] == 'O')
    {
        return 2;
    }

    else if (upperWord[len - 1] == 'Z')
    {
        return 2;
    }
    else if (upperWord[len - 1] == 'F' && upperWord[len - 2] == 'E')
    {
        return 3;
    }
    else if (upperWord[len - 1] == 'F')
    {
        return 3;
    }
    else if (upperWord[len - 1] == 'Y')
    {
        return 4;
    }
    else
    {
        return 5;
    }
}


void ApplyRule(int rule, char upperWord[], char pluralUpperWord[]) 
{
    int length = strlen(pluralUpperWord);

    if (rule == 1) 
    {
        pluralUpperWord[length - 2] = 'I';
        pluralUpperWord[length - 1] = '\0';
    }
    if (rule == 2)
    {
        strcat(pluralUpperWord, "ES");
    }
    if (rule == 3)
    {
        if (pluralUpperWord[length - 1] == 'F')
        {
            pluralUpperWord[length - 1] = '\0';
            strcat(pluralUpperWord, "VES");
        }
        else
        {
            pluralUpperWord[length - 1] = '\0';
            pluralUpperWord[length - 2] = '\0';
            strcat(pluralUpperWord, "VES");
        }
    }
    if (rule == 4)
    {
        pluralUpperWord[length - 1] = 'I';
        strcat(pluralUpperWord, "ES");
    }
    if (rule == 5)
    {
        strcat(pluralUpperWord, "S");
    }
}


void MakePlural(char upperWord[], char pluralUpperWord[])
{

    int rule = DetermineRULE(upperWord);
    printf("\nThe rule num is : % d", rule);
    ApplyRule(rule, upperWord, pluralUpperWord);
}


